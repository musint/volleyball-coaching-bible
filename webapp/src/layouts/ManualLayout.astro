---
import DefaultLayout from './DefaultLayout.astro';

interface Props {
  title: string;
  description?: string;
  age?: string;
}
const { title, description, age } = Astro.props;
const base = import.meta.env.BASE_URL;
const ages = ['10s','11s','12s','13s','14s','15s','16s','17s','18s'];
---
<DefaultLayout {title} {description}>
  <div class="max-w-6xl mx-auto px-4 py-6 grid md:grid-cols-[14rem_1fr] gap-8">
    <aside class="text-sm md:sticky md:top-20 md:self-start no-print">
      <div class="space-y-6">
        <div>
          <h3 class="font-serif text-xs uppercase tracking-wider text-stone-500 mb-2">Age guides</h3>
          <ul class="space-y-1">
            {ages.map(a => (
              <li>
                <a
                  href={`${base}/manual/ages/${a}/`}
                  class:list={["block px-2 py-1 rounded no-underline",
                    age === a ? "bg-orange-100 text-orange-900 font-semibold" : "text-stone-700 hover:bg-stone-100"]}
                >
                  {a}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-serif text-xs uppercase tracking-wider text-stone-500 mb-2">Cue dictionary</h3>
          <ul class="space-y-1">
            <li><a href={`${base}/manual/cues/`} class="block px-2 py-1 rounded text-stone-700 hover:bg-stone-100 no-underline">All skills</a></li>
            {['passing','setting','hitting','blocking','serving','defense','transition'].map(s => (
              <li><a href={`${base}/manual/cues/${s}-cues/`} class="block px-2 py-1 rounded text-stone-700 hover:bg-stone-100 no-underline">{s}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-serif text-xs uppercase tracking-wider text-stone-500 mb-2">More</h3>
          <ul class="space-y-1">
            <li><a href={`${base}/manual/drill-picks/`} class="block px-2 py-1 rounded text-stone-700 hover:bg-stone-100 no-underline">Drill pick-lists</a></li>
            <li><a href={`${base}/manual/tryouts/`} class="block px-2 py-1 rounded text-stone-700 hover:bg-stone-100 no-underline">Tryout rubrics</a></li>
            <li><a href={`${base}/manual/practice-plans/`} class="block px-2 py-1 rounded text-stone-700 hover:bg-stone-100 no-underline">Practice plans</a></li>
            <li><a href={`${base}/ops/`} class="block px-2 py-1 rounded text-stone-700 hover:bg-stone-100 no-underline">Operations</a></li>
          </ul>
        </div>
      </div>
    </aside>
    <article class="prose-bible">
      <slot />
    </article>
  </div>
</DefaultLayout>
