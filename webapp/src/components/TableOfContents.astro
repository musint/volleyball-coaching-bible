---
// Table of contents auto-generated from h2/h3 headings.
// Two variants:
//   variant="mobile"  — collapsible <details> at top of article (renders <lg only)
//   variant="desktop" — sticky right sidebar (renders >=lg only)
// Render both for non-manual pages (so coaches see TOC on any width);
// render only "mobile" for manual pages (which already have a left sidebar).

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
  variant: 'mobile' | 'desktop';
  minHeadings?: number;
}

const { headings, variant, minHeadings = 4 } = Astro.props;
const items = (headings || []).filter((h) => h.depth === 2 || h.depth === 3);
const showToc = items.length >= minHeadings;
---
{showToc && variant === 'mobile' && (
  <details class="toc-mobile no-print">
    <summary>
      <span class="kicker">On this page</span>
      <span class="toc-mobile-count">{items.length} sections</span>
    </summary>
    <ul class="toc-list">
      {items.map((h) => (
        <li class={`toc-item toc-depth-${h.depth}`}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </details>
)}

{showToc && variant === 'desktop' && (
  <nav class="toc-desktop no-print" aria-label="On this page">
    <div class="kicker toc-desktop-kicker">On this page</div>
    <ul class="toc-list">
      {items.map((h) => (
        <li class={`toc-item toc-depth-${h.depth}`}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc-mobile {
    margin: 0 0 1.25rem 0;
    border: 1px solid var(--color-rule);
    border-radius: 0.5rem;
    background: #fffdf7;
    font-family: var(--font-sans);
  }
  .toc-mobile summary {
    list-style: none;
    cursor: pointer;
    padding: 0.6rem 0.9rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .toc-mobile summary::-webkit-details-marker { display: none; }
  .toc-mobile summary::after {
    content: '▾';
    color: var(--color-muted);
    transition: transform 0.15s;
  }
  .toc-mobile[open] summary::after {
    transform: rotate(180deg);
  }
  .toc-mobile-count {
    font-size: 0.78rem;
    color: var(--color-muted);
  }
  .toc-mobile ul {
    list-style: none;
    margin: 0;
    padding: 0 0.9rem 0.6rem 0.9rem;
    border-top: 1px solid var(--color-rule);
    padding-top: 0.5rem;
  }
  /* Hide mobile TOC at lg breakpoint; the desktop sidebar takes over */
  @media (min-width: 1024px) {
    .toc-mobile { display: none; }
  }

  .toc-desktop {
    display: none;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  @media (min-width: 1024px) {
    .toc-desktop {
      display: block;
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      padding: 0.5rem 0;
    }
  }
  .toc-desktop-kicker {
    margin-bottom: 0.6rem;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .toc-item {
    margin: 0;
    line-height: 1.35;
  }
  .toc-item a {
    display: block;
    padding: 0.25rem 0;
    color: var(--color-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    padding-left: 0.6rem;
    transition: color 0.1s, border-color 0.1s;
  }
  .toc-item a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }
  .toc-depth-2 a {
    font-weight: 600;
    color: var(--color-ink);
  }
  .toc-depth-3 a {
    padding-left: 1.4rem;
    font-size: 0.85rem;
  }
</style>
