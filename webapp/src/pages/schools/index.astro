---
import { getCollection } from 'astro:content';
import DefaultLayout from '../../layouts/DefaultLayout.astro';

const schools = await getCollection('school');
const base = import.meta.env.BASE_URL;

// Bucket schools by rough type. Methodology / national-tradition / institutional / federation.
function bucket(s: any): string {
  const id = s.id;
  if (['gold-medal-squared','art-of-coaching-volleyball','japanese-training','usa-volleyball','ecological-dynamics','game-based-training','block-vs-random-practice'].includes(id))
    return 'Methodology + preferred';
  if (['russian-school','brazilian-school','italian-school','polish-school','french-school','serbian-school','cuban-school','korean-school','chinese-volleyball-tradition'].includes(id))
    return 'National traditions';
  if (['pzps-poland','ffv-france','oss-serbia','fcv-cuba','kva-korea'].includes(id))
    return 'Federations';
  return 'Institutional traditions';
}

const buckets: Record<string, typeof schools> = {};
for (const s of schools) {
  (buckets[bucket(s)] ||= []).push(s);
}
const order = ['Methodology + preferred','National traditions','Federations','Institutional traditions'];
---
<DefaultLayout title="Schools" description="Schools of thought.">
  <section class="max-w-6xl mx-auto px-4 py-10">
    <h1 class="font-serif text-4xl font-bold text-stone-900 mb-2">Schools of thought</h1>
    <p class="text-stone-600 mb-8 max-w-2xl">{schools.length} schools, traditions, federations, and institutional programs.</p>

    {order.filter(b => buckets[b]).map(b => (
      <section class="mb-8">
        <h2 class="font-serif text-xl font-bold text-stone-900 border-b border-stone-200 pb-1 mb-3">{b}</h2>
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {buckets[b].sort((a,b) => a.data.name.localeCompare(b.data.name)).map(s => (
            <li>
              <a href={`${base}/schools/${s.id}/`} class="block p-3 border border-stone-200 rounded-md hover:border-orange-400 hover:bg-orange-50 no-underline">
                <div class="font-semibold text-stone-900">{s.data.name}</div>
                <div class="text-xs text-stone-500">{s.data.origin}</div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</DefaultLayout>
