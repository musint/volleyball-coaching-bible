---
import DefaultLayout from '../layouts/DefaultLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<DefaultLayout title="Search" description="Site-wide search">
  <section class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="font-serif text-3xl font-bold text-stone-900 mb-3">Search</h1>
    <p class="text-stone-600 mb-6">Full-text search across the manual, library, drills, coaches, and sources.</p>
    <div id="search"></div>
  </section>
  <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
  <script src={`${base}/pagefind/pagefind-ui.js`} is:inline></script>
  <script is:inline define:vars={{base}}>
    window.addEventListener('DOMContentLoaded', () => {
      // PagefindUI is loaded by the script tag above
      if (typeof PagefindUI === 'undefined') return;
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        bundlePath: base + '/pagefind/',
      });
    });
  </script>
</DefaultLayout>
