# Obsidian workspace (personal to each user's Obsidian install)
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
*.swp
*.tmp

# Python
__pycache__/
*.pyc
.pytest_cache/

# Owned book PDFs that shouldn't be committed to shared repos
# (user may redistribute this repo; copyrighted PDFs stay local)
raw/books/*.pdf

# Large binary media pending transcription (Task 3.2 deferred assets)
# The .deferred marker inside such folders IS committed; the binary is not.
Munciana Drills/*.mp4
*.mp4
*.mov
*.mkv

# Git worktrees (local isolation for feature branches)
.worktrees/

# Privacy: not pushed to public repo
# - raw/articles/ — extracted article texts; fair use for private analysis but
#   pushing verbatim to a public repo is one step further than needed
# - raw/transcripts/munciana-2022-camp-drills.md — private internal staff video
raw/articles/
raw/transcripts/munciana-2022-camp-drills.md

# Local backups (never commit)
*.backup-*

# Astro / Node
webapp/node_modules/
webapp/dist/
webapp/.astro/
webapp/.env
webapp/.env.local
node_modules/
